# 服务器配置
PORT=14110
NODE_ENV=development

# 数据库配置
DB_NAME=ai_testcase_generator
DB_USER=root
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=3306
DB_DIALECT=mysql

# 数据库同步配置
DB_SYNC=false

# JWT配置
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# AI 配置 (Gemini 或 OpenAI兼容协议)
# 供应商: gemini (默认) 或 openai
AI_PROVIDER=gemini
# 供应商名称 (仅在 provider=openai 时显示)
AI_PROVIDER_NAME=
# API Key (必填)
AI_API_KEY=your_api_key
# API 地址 (选填，默认 Gemini: https://generativelanguage.googleapis.com/v1beta, OpenAI: https://api.openai.com/v1)
AI_API_URL=
# 模型名称 (选填，不填则使用代码默认值)
AI_MODEL=

# 日志配置
LOG_LEVEL=debug

# 禅道集成配置 (可选)
ZENTAO_URL=
ZENTAO_COOKIE=